APP_NAME="numa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=carriereos
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_TABLE=queue_jobs

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=numa
MAIL_PASSWORD=numa
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.test"
MAIL_FROM_NAME="${APP_NAME}"

GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-flash-latest,gemini-2.5-pro
GEMINI_LOCAL_STUB_ENABLED=false
GEMINI_MAX_ATTEMPTS=3
GEMINI_TIMEOUT_SECONDS=30
SETUP_ADMIN_IPS=127.0.0.1,::1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI="${APP_URL}/admin/integrations/linkedin/callback"
LINKEDIN_SCOPES=openid,profile,email,w_member_social

VITE_APP_NAME="${APP_NAME}"

MULTIPOSTING_AUTOMATION_ENABLED=false
MULTIPOSTING_AUTOMATION_PLATFORMS=linkedin,indeed
MULTIPOSTING_AUTOMATION_QUEUE=automation
COMMUNICATION_OUTBOX_QUEUE=default
MULTIPOSTING_AUTOMATION_TIMEOUT_SECONDS=180
MULTIPOSTING_AUTOMATION_NODE_BINARY=node
MULTIPOSTING_AUTOMATION_SCRIPT_PATH=scripts/rpa/post-job.mjs
MULTIPOSTING_AUTOMATION_HEADLESS=true
MULTIPOSTING_AUTOMATION_SCREENSHOT_DIR=storage/app/private/rpa_failures
RPA_ALLOW_INTERACTIVE_LOGIN=false
RPA_INTERACTIVE_LOGIN_WAIT_SECONDS=180
RPA_POST_FORM_READY_TIMEOUT_SECONDS=180
RPA_LINKEDIN_EMAIL=
RPA_LINKEDIN_PASSWORD=
RPA_LINKEDIN_SESSION_STATE_PATH=storage/app/private/rpa_sessions/linkedin.json
RPA_LINKEDIN_LOGIN_URL=https://www.linkedin.com/login
RPA_LINKEDIN_COOKIES_JSON=
RPA_LINKEDIN_SELECTORS_PATH=scripts/rpa/selectors/linkedin.json
RPA_INDEED_EMAIL=
RPA_INDEED_PASSWORD=
RPA_INDEED_SESSION_STATE_PATH=storage/app/private/rpa_sessions/indeed.json
RPA_INDEED_LOGIN_URL=https://secure.indeed.com/account/login
RPA_INDEED_COOKIES_JSON=
RPA_INDEED_SELECTORS_PATH=scripts/rpa/selectors/indeed.json

CHATBOT_URL=http://localhost:3000
