APP_NAME="numa"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.example.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres.internal
DB_PORT=5432
DB_DATABASE=numa
DB_USERNAME=numa
DB_PASSWORD=change-me

MAIL_MAILER=smtp
MAIL_HOST=mail.internal
MAIL_PORT=587
MAIL_USERNAME=change-me
MAIL_PASSWORD=change-me
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@app.example.com

FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database
DB_QUEUE_TABLE=queue_jobs
GEMINI_API_KEY=change-me
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-flash-latest,gemini-2.5-pro
GEMINI_LOCAL_STUB_ENABLED=false
GEMINI_MAX_ATTEMPTS=3
GEMINI_TIMEOUT_SECONDS=30
SETUP_ADMIN_IPS=127.0.0.1

MULTIPOSTING_AUTOMATION_ENABLED=false
MULTIPOSTING_AUTOMATION_PLATFORMS=linkedin,indeed
MULTIPOSTING_AUTOMATION_QUEUE=automation
COMMUNICATION_OUTBOX_QUEUE=default
MULTIPOSTING_AUTOMATION_TIMEOUT_SECONDS=180
MULTIPOSTING_AUTOMATION_NODE_BINARY=node
MULTIPOSTING_AUTOMATION_SCRIPT_PATH=scripts/rpa/post-job.mjs
MULTIPOSTING_AUTOMATION_HEADLESS=true
MULTIPOSTING_AUTOMATION_SCREENSHOT_DIR=storage/app/private/rpa_failures
RPA_ALLOW_INTERACTIVE_LOGIN=false
RPA_INTERACTIVE_LOGIN_WAIT_SECONDS=180
RPA_POST_FORM_READY_TIMEOUT_SECONDS=180
RPA_LINKEDIN_EMAIL=
RPA_LINKEDIN_PASSWORD=
RPA_LINKEDIN_SESSION_STATE_PATH=storage/app/private/rpa_sessions/linkedin.json
RPA_LINKEDIN_LOGIN_URL=https://www.linkedin.com/login
RPA_LINKEDIN_COOKIES_JSON=
RPA_LINKEDIN_SELECTORS_PATH=scripts/rpa/selectors/linkedin.json
RPA_INDEED_EMAIL=
RPA_INDEED_PASSWORD=
RPA_INDEED_SESSION_STATE_PATH=storage/app/private/rpa_sessions/indeed.json
RPA_INDEED_LOGIN_URL=https://secure.indeed.com/account/login
RPA_INDEED_COOKIES_JSON=
RPA_INDEED_SELECTORS_PATH=scripts/rpa/selectors/indeed.json

